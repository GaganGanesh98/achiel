# Copy to .env and fill secrets. JSON for domains can match allowed_domains.example.json (single line).

DATABASE_URL=postgresql+asyncpg://campusvoice:campusvoice@localhost:5432/campusvoice
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OTP email: Resend (preferred) or SMTP. Logs OTP to console when neither is set.
RESEND_API_KEY=
RESEND_FROM=CampusVoice <onboarding@resend.dev>
SMTP_HOST=
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@campusvoice.app
SMTP_TLS=false

APP_BASE_URL=http://localhost:3000
ENV=development

CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Registration: skip email verification when true (local dev only)
DEV_AUTO_VERIFY=true

# Placeholder for future SMTP / transactional email sender address
EMAIL_SENDER=

# Optional extra severe terms (JSON array); bundled severe_terms.txt is always loaded
SEVERE_TERMS_JSON=[]
# German severe terms file (severe_terms_de.txt) + optional JSON overlay for production slurs
SEVERE_TERMS_DE_JSON=[]

# OpenAI omni-moderation-latest (multilingual). Omit for word-list-only degraded mode.
OPENAI_API_KEY=

# University domains JSON: domain -> {name, country, city?}
ALLOWED_EMAIL_DOMAINS={"mit.edu":{"name":"MIT","country":"US","city":"Cambridge"},"stanford.edu":{"name":"Stanford University","country":"US","city":"Stanford"}}
