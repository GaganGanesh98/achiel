# Copy to .env and fill secrets. JSON for domains can match allowed_domains.example.json (single line).

DATABASE_URL=postgresql+asyncpg://campusvoice:campusvoice@localhost:5432/campusvoice
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional SMTP (OTP is printed to server logs when SMTP_HOST is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@campusvoice.app

# University domains JSON: domain -> {name, country, city?}
ALLOWED_EMAIL_DOMAINS={"mit.edu":{"name":"MIT","country":"US","city":"Cambridge"},"stanford.edu":{"name":"Stanford University","country":"US","city":"Stanford"}}
